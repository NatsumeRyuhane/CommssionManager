# Commission Manager production Docker Compose configuration.
# Copy this file to deploy/.env before starting the production stack.
#
# Generate URL-safe secrets with:
#   openssl rand -hex 32
#
# POSTGRES_PASSWORD is embedded directly in the API database URL, so keep it
# URL-safe (the hexadecimal output from the command above is suitable).

POSTGRES_PASSWORD=replace-with-generated-hex-password
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-admin-password
SECRET_KEY=replace-with-generated-hex-secret
CORS_ORIGINS=["https://commission.example.com"]

# Optional settings
ACCESS_TOKEN_EXPIRE_MINUTES=10080
STORAGE_BACKEND=local
