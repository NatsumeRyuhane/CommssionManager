# Commission Manager production Docker Compose configuration.
# Copy this file to deploy/.env before starting the production stack.
#
# Generate URL-safe secrets with:
#   openssl rand -hex 32
#
# The default stack uses its bundled Postgres container; no DB_* settings are
# required. To use an external database instead, uncomment all settings below.
# DB_USER and DB_PASSWORD are embedded directly in the API database URL, so keep
# them URL-safe (the hexadecimal output from the command above is suitable).
#
# COMPOSE_FILE=deploy/docker-compose.yml:deploy/docker-compose.external-db.yml
# DB_HOST=database.example.com
# DB_PORT=5432
# DB_NAME=commission_manager
# DB_USER=cmgr
# DB_PASSWORD=replace-with-generated-hex-password

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-admin-password
SECRET_KEY=replace-with-generated-hex-secret
CORS_ORIGINS=["https://commission.example.com"]

# Optional settings
APP_PORT=8080
ACCESS_TOKEN_EXPIRE_MINUTES=10080
STORAGE_BACKEND=local
