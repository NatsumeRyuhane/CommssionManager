// Commission Manager Database Schema
// Current backend schema. See docs/architecture.md for drift from docs/requirements.xml.

Project commission_manager {
  database_type: 'PostgreSQL'
  Note: 'Commission art management application'
}

//----------------------------------------------------------------------
// Enums
//----------------------------------------------------------------------

// Label types differ only in frontend display semantics; the backend treats all labels identically
// for categories and tags. `rating` remains in the enum for compatibility with the original
// requirements draft, but current commission rating is stored on commission_metadata.rating.
Enum label_type {
  category
  tag
  rating
}

Enum rating {
  general
  mature
  adult
}

Enum visibility {
  public
  private
}

Enum visibility_preset {
  public_by_default
  private_by_default
  custom
}

//----------------------------------------------------------------------
// Core lookup tables
//----------------------------------------------------------------------

Table labels {
  id         integer     [pk, increment]
  name       varchar     [not null, unique]
  type       label_type  [not null]

  Note: 'Unified lookup for categories and tags. label_type.rating exists for compatibility, but the current backend stores each commission rating on commission_metadata.rating.'
}

Table characters {
  id           integer  [pk, increment]
  name         varchar  [not null, Note: 'First-class column; used for DB-level search and filtering']
  settings_xml text     [Note: 'XML blob for all other character attributes (species, appearance, lore, etc.); parsed by the frontend']

  Note: 'Characters that appear in commissions. Species filtering operates at the application layer via XML parsing, not the DB layer.'
}

Table artists {
  id           integer  [pk, increment]
  name         varchar  [not null, Note: 'First-class column; used for DB-level search and filtering']
  info_xml text     [Note: 'XML blob for all other artist attributes (contact links, social handles, notes, etc.); parsed by the frontend']

  Note: 'Artists who created the commission work.'
}

//----------------------------------------------------------------------
// Auth
//----------------------------------------------------------------------

Table api_keys {
  id           integer   [pk, increment]
  name         varchar   [not null]
  prefix       varchar   [not null]
  key_hash     varchar   [not null, Note: 'SHA-256 hash of the full API key; the full key is shown only once on creation']
  scopes       varchar   [not null, default: 'read', Note: 'Space-delimited scopes, currently read/write']
  created_at   timestamp [default: `now()`]
  last_used_at timestamp
  revoked_at   timestamp

  indexes {
    prefix
  }

  Note: 'Scoped machine/agent credentials. API keys can read publicly available data and require write scope for edit endpoints; API key management is admin-only.'
}

//----------------------------------------------------------------------
// Storage abstraction
//----------------------------------------------------------------------

Enum storage_backend {
  local  [Note: 'Local filesystem; key is a relative file path']
  s3     [Note: 'Amazon S3 or S3-compatible; bucket + key']
  gcs    [Note: 'Google Cloud Storage; bucket + key']
}

Table storage_objects {
  id         integer         [pk, increment]
  backend    storage_backend [not null]
  bucket     varchar         [Note: 'Container name (S3/GCS bucket). Null for local backend.']
  key        varchar         [not null, Note: 'Backend-specific locator: relative path for local, object key for S3/GCS']
  size_bytes bigint          [Note: 'File size in bytes']
  checksum   varchar         [Note: 'SHA-256 hex digest for integrity verification']
  created_at timestamp       [default: `now()`]

  indexes {
    (backend, bucket, key) [unique]
  }

  Note: 'Backend-agnostic pointer to a stored file. Adding a new backend requires no schema change — only a new enum value and application-side handler.'
}

//----------------------------------------------------------------------
// Settings
//----------------------------------------------------------------------

Table app_settings {
  id                            integer           [pk]
  site_title                    varchar           [not null, default: 'Commissions']
  default_stage_names           varchar           [not null, default: 'Delivered, Color, Lineart, Sketching', note: 'comma-separated stage template for new commissions, display order (first = topmost)']
  allow_public_original_download boolean          [not null, default: true, note: 'when false, visitors get lossy derivatives only: /raw and png derivatives require write access']
  visibility_preset             visibility_preset [not null, default: 'public_by_default']
  default_commission_visibility visibility        [not null, default: 'public']
  default_stage_visibility      visibility        [not null, default: 'private']
  title_public                  boolean           [not null, default: true]
  description_public            boolean           [not null, default: true]
  labels_public                 boolean           [not null, default: true]
  rating_public                 boolean           [not null, default: true]
  characters_public             boolean           [not null, default: true]
  artists_public                boolean           [not null, default: true]
  confirmed_at_public           boolean           [not null, default: false]
  price_public                  boolean           [not null, default: false]
  allow_direct_upload           boolean           [not null, default: false, note: 'admin toggle: when true and the configured backend supports it, browsers PUT bytes straight to object storage instead of routing through the app']
  updated_at                    timestamp         [default: `now()`]

  Note: 'Singleton admin settings row. Visibility defaults apply to new/public views unless overridden by commission, stage, or file visibility.'
}

Table upload_sessions {
  id                  varchar(32)     [pk, note: 'opaque session identifier returned to the client']
  node_id             integer         [not null, ref: > commission_nodes.id, note: 'destination stage; FK cascades on node delete']
  storage_backend     storage_backend [not null]
  storage_bucket      varchar         [note: 'bucket the presign was issued against; null for local backend (which never presigns)']
  storage_key         varchar         [not null, unique, note: 'pre-generated object key; uniqueness guards against double-finalize creating duplicate files']
  filename            varchar         [not null]
  content_type        varchar         [not null]
  expected_size_bytes bigint          [not null, note: 'client-declared; finalize verifies it against HeadObject before creating records']
  label               varchar
  expires_at          timestamp       [not null, note: 'when the presigned URL stops being valid; expired+unfinalized sessions are cleaned up']
  created_at          timestamp       [default: `now()`]
  finalized_at        timestamp       [note: 'set when the upload was registered as a CommissionFile; finalization is idempotent on this column']
  commission_file_id  integer         [ref: > commission_files.id, note: 'populated on finalization; SET NULL if the file is later deleted']

  indexes {
    node_id
  }

  Note: 'Pending browser-direct upload. Bytes go straight from the browser to object storage via a presigned PUT; the server creates this row, hands back the URL, and after the PUT verifies the object and creates the CommissionFile.'
}

Table visibility_stage_defaults {
  id         integer    [pk, increment]
  stage_name varchar    [not null, unique]
  visibility visibility [not null]
  position   integer    [not null, default: 0]
  note       varchar

  Note: '''
    Global stage-name defaults used when lifecycle stages are created or when an existing stage
    has no explicit override. Factory seed rows ship in chronological order:
    Sketching (0) → Lineart (1) → Color (2) → Delivered (3); the first three default to private
    (WIP) and Delivered defaults to public (final deliverables).
  '''
}

Table webhook_endpoints {
  id               integer   [pk, increment]
  url              varchar   [not null]
  events           varchar   [not null, Note: 'Space-delimited event names: commission.created, commission.updated, commission.delivered']
  is_enabled       boolean   [not null, default: true]
  created_at       timestamp [default: `now()`]
  updated_at       timestamp [default: `now()`]
  last_delivery_at timestamp
  last_status_code integer
  last_error       text

  Note: 'Admin-managed webhook endpoints. Delivery workers are a later Phase 2 slice; this table stores endpoint config and last delivery summary.'
}

//----------------------------------------------------------------------
// Commission
//----------------------------------------------------------------------

Table commissions {
  id         integer   [pk, increment]
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]

  Note: 'Physical commission record. Descriptive fields live in commission_metadata. Storage location is managed via storage_objects.'
}

Table commission_metadata {
  id              integer        [pk, increment]
  commission_id   integer        [not null, ref: - commissions.id, Note: 'One-to-one with commissions']
  title           varchar        [Note: 'Nullable; null means untitled and the UI hides it']
  description     text
  rating          rating         [not null, default: 'general']
  cover_file_id   integer        [ref: - commission_files.id, Note: 'Nullable; must point to a commission_file where is_image = true']
  confirmed_at    timestamp      [Note: 'When the commission was accepted/confirmed by the admin']
  price_amount    numeric(12, 2) [Note: 'Agreed commission price']
  price_currency  varchar(3)     [Note: 'ISO 4217 currency code, e.g. USD, JPY, CNY']
  visibility_override          visibility [Note: 'Nullable commission-level override. Null inherits app_settings.default_commission_visibility.']
  title_public_override        boolean    [Note: 'Nullable field-level public/private override. Null inherits app_settings.']
  description_public_override  boolean
  labels_public_override       boolean
  rating_public_override       boolean
  characters_public_override   boolean
  artists_public_override      boolean
  confirmed_at_public_override boolean
  price_public_override        boolean

  Note: 'All descriptive metadata for a commission grouped in one place. Rating is a first-class enum column here; commission_labels currently stores categories and tags.'
}

//----------------------------------------------------------------------
// Commission files (one-to-many with node)
//----------------------------------------------------------------------

Table commission_files {
  id                integer   [pk, increment]
  node_id           integer   [not null, ref: > commission_nodes.id, Note: 'Files belong to a node, not directly to a commission. Use the detached node for uncategorized files.']
  storage_object_id integer   [not null, ref: - storage_objects.id]
  position          integer   [not null, Note: 'Admin-defined ordering within the lifecycle node; lower values come first.']
  format            varchar   [not null, Note: 'File extension: png, jpg, psd, sai2, etc.']
  label             varchar   [Note: 'Optional human-readable description, e.g. "with background", "no watermark", "差分 A"']
  // Image-specific fields — null for non-image files (psd, sai2, design files, etc.)
  is_image          boolean   [not null, default: false, Note: 'True if this file can be rendered as a displayable image (e.g. png, jpg). False for psd, sai2, zip, etc.']
  width             integer   [Note: 'Pixel width; null when is_image = false']
  height            integer   [Note: 'Pixel height; null when is_image = false']
  focal_x           float     [Note: 'Relative X of the main subject center (0.0–1.0) for thumbnail cropping; null when is_image = false']
  focal_y           float     [Note: 'Relative Y of the main subject center (0.0–1.0) for thumbnail cropping; null when is_image = false']
  focal_zoom        float     [Note: 'Crop zoom factor (1.0–3.0) applied around the focal point when rendering covers/thumbnails; 1.0 = no zoom, null when is_image = false']
  visibility_override visibility [Note: 'Nullable file-level override. Highest-precedence visibility control for public image filtering, except files in detached nodes are always private.']
  created_at        timestamp [default: `now()`]

  indexes {
    (node_id, position) [unique]
  }

  Note: 'Any file received as part of a commission: rendered images, source files, design docs, etc. Only files with is_image = true are eligible as cover art.'
}

//----------------------------------------------------------------------
// Commission lifecycle
//----------------------------------------------------------------------

Table commission_nodes {
  id            integer   [pk, increment]
  commission_id integer   [not null, ref: > commissions.id]
  name          varchar   [not null, Note: 'Stage name, e.g. "Sketching", "Lineart", "Delivered"']
  position      integer   [Note: 'Admin-defined ordering; lower values come first. NULL for the detached node.']
  started_at    timestamp [Note: 'When this stage began. NULL for the detached node.']
  is_detached   boolean   [not null, default: false, Note: 'True for the one system-managed detached node per commission. Detached nodes cannot be deleted, reordered, or made public.']
  visibility_override visibility [Note: 'Nullable stage-level override. Null inherits the matching visibility_stage_defaults row or app_settings.default_stage_visibility.']

  indexes {
    (commission_id, position) [unique]
    // Uniqueness of the detached node per commission must be enforced at the application layer (partial unique index: commission_id WHERE is_detached = true)
  }

  Note: 'Ordered lifecycle stages for a commission. Each commission has exactly one detached node (is_detached=true), auto-created with the commission and used as a holding area for images whose node was deleted.'
}


//----------------------------------------------------------------------
// Junction tables
//----------------------------------------------------------------------

Table commission_labels {
  commission_id integer [not null, ref: > commissions.id]
  label_id      integer [not null, ref: > labels.id]

  indexes {
    (commission_id, label_id) [pk]
  }

  Note: 'Many-to-many: a commission can have multiple categories and tags.'
}

Table commission_characters {
  commission_id integer [not null, ref: > commissions.id]
  character_id  integer [not null, ref: > characters.id]

  indexes {
    (commission_id, character_id) [pk]
  }

  Note: 'Many-to-many: a commission can feature multiple characters.'
}

Table commission_artists {
  commission_id integer [not null, ref: > commissions.id]
  artist_id     integer [not null, ref: > artists.id]

  indexes {
    (commission_id, artist_id) [pk]
  }

  Note: 'Many-to-many: a commission can be created by multiple artists (co-commission).'
}

//----------------------------------------------------------------------
// Character pages
//----------------------------------------------------------------------

Table character_pages {
  id                           integer   [pk, increment]
  character_id                 integer   [not null, unique, ref: - characters.id, Note: 'One page per character; cascades when the character is deleted']
  about                        text      [Note: 'Free-form public bio shown on the page']
  main_reference_commission_id integer   [ref: - commissions.id, Note: 'Pinned commission whose cover image is the main reference; on commission delete the FK is set to NULL']
  created_at                   timestamp [default: `now()`]
  updated_at                   timestamp [default: `now()`]

  Note: 'Public, shareable profile for a character. Presence of a row drives the CharacterOut.has_page flag the frontend uses to mark characters that have pages.'
}

Table character_image_sets {
  id          integer   [pk, increment]
  page_id     integer   [not null, ref: > character_pages.id, Note: 'Cascades when the page is deleted']
  title       varchar   [not null]
  description text
  position    integer   [not null, default: 0]
  created_at  timestamp [default: `now()`]
  updated_at  timestamp [default: `now()`]

  indexes {
    (page_id, position) [unique]
  }

  Note: 'Curated horizontal "bookshelves" of commissions whose cover images are showcased on a character page; admin-picked, manually ordered.'
}

Table character_image_set_items {
  id            integer [pk, increment]
  set_id        integer [not null, ref: > character_image_sets.id, Note: 'Cascades when the set is deleted']
  commission_id integer [not null, ref: > commissions.id, Note: 'Cascades when the commission is deleted; the displayed image is that commission’s cover']
  position      integer [not null, default: 0]

  indexes {
    (set_id, commission_id) [unique]
    (set_id, position) [unique]
  }

  Note: 'Commissions included in a curated set, in admin-defined display order. Each commission may only appear once per set; the rendered tile uses the commission’s cover image.'
}
