# Commission Manager backend configuration.
# All settings are required (no in-code defaults). Copy to `.env` for local dev:
#     cp .env.example .env
# `.env` is gitignored. In production, supply these as real environment variables
# (e.g. via docker-compose) and use strong, unique secrets.

# Deployment mode used by the deploy/ tooling (deploy/setup.py, deploy/main.py) to decide
# how to run the app: dev (host servers w/ hot reload), test (run the suite), prod (full
# Docker stack). Ignored by the backend itself.
CMGR_ENV=dev

# Database — SQLAlchemy URL. The dev value targets docker-compose.dev.yml's Postgres
# (host port 55432 to avoid clashing with a system Postgres on 5432).
CMGR_DATABASE_URL=postgresql+psycopg://cmgr:cmgr@localhost:55432/commission_manager

# Admin login (single owner). CHANGE THESE IN PRODUCTION.
CMGR_ADMIN_USERNAME=admin
CMGR_ADMIN_PASSWORD=changeme

# Session/JWT signing secret + token lifetime (minutes). CHANGE THE SECRET IN PRODUCTION
# (use e.g. `openssl rand -hex 32`; HS256 wants >= 32 bytes).
CMGR_SECRET_KEY=dev-insecure-secret-change-me
CMGR_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Storage backend + local filesystem root.
CMGR_STORAGE_BACKEND=local
CMGR_STORAGE_LOCAL_ROOT=./data/storage

# CORS allowed origins — JSON array. Dev runs the Vite server on :5173.
CMGR_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
